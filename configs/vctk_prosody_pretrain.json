{
  "train": {
    "log_interval": 100,
    "eval_interval": 500,
    "seed": 1234,
    "epochs": 100,
    "learning_rate": 2e-4,
    "betas": [0.9, 0.98],
    "eps": 1e-9,
    "batch_size": 64,
    "fp16_run": false
  },
  "data": {
    "training_files": "filelists/vctk_audio_sid_text_train.txt.prosody",
    "validation_files": "filelists/vctk_audio_sid_text_val.txt.prosody",
    "text_cleaners": ["english_cleaners"],
    "sampling_rate": 22050,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024
  },
  "model": {
    "inter_channels": 192,
    "hidden_channels": 192,
    "n_heads": 2,
    "gin_channels": 256
  },
  "research": {
    "use_prosody_encoder": true,
    "fusion_type": "cross_attention",
    "disentangle_loss": "none",
    "disentangle_weight": 0.0,
    "prosody_dim": 128,
    "timbre_dim": 192
  }
}
